@model pdfDSNFT.Models.DocumentoModel

@{
    ViewData["Title"] = "Formulario PDF";

}
<a asp-action="Historial" class="btn btn-secondary">Ver Historial</a>

<h2>Generar Documento</h2>

<form method="post" asp-action="Formulario">

    <div asp-validation-summary="All" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="Codigo" class="form-label"></label>
        <input asp-for="Codigo" type="number" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Version" class="form-label"></label>
        <input asp-for="Version" type="number" class="form-control" />
    </div>


    <div class="mb-3">
        <label asp-for="Titulo" class="form-label"></label>
        <input asp-for="Titulo" class="form-control" />
        <span asp-validation-for="Titulo" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="MesaSectorial" class="form-label"></label>
        <input asp-for="MesaSectorial" class="form-control" />
        <span asp-validation-for="MesaSectorial" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Fecha" class="form-label"></label>
        <input asp-for="Fecha" type="date" class="form-control" />
        <span asp-validation-for="Fecha" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <div class="form-check">
            <input asp-for="ValidacionInicial" class="form-check-input" id="chkIniValidacion" />
            <label asp-for="ValidacionInicial" class="form-check-label"></label>
        </div>
        <div id="Fechavalini" style="display:none;" class="mt-3">
            <label asp-for="FechaValidacionInicial" class="form-label">Fecha validacion inicial</label>
            <input asp-for="FechaValidacionInicial" type="datetime-local" step="1" class="form-control" />
        </div>
      

        <div class="form-check">
            <input asp-for="PostValidacion" class="form-check-input" id="chkPostValidacion" />
            <label asp-for="PostValidacion" class="form-check-label"></label>
        </div>
        <div id="FechaPostValidacion" style="display:none;" class="mt-3">
            <label asp-for="FechaPostValidacion" class="form-label">Fecha postvalidacion</label>
            <input asp-for="FechaPostValidacion" type="datetime-local" step="1" class="form-control" />
        </div>
    </div>

    <button type="submit" class="btn btn-success btn-lg">Generar</button>

</form>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const checkbox = document.getElementById("chkPostValidacion");
            const campo = document.getElementById("FechaPostValidacion");

            checkbox.addEventListener("change", function () {
                campo.style.display = checkbox.checked ? "block" : "none";
            });

            const checkboxvalini = document.getElementById("chkIniValidacion");
            const campfechini = document.getElementById("Fechavalini");

            checkboxvalini.addEventListener("change", function () {
              campfechini.style.display = checkboxvalini.checked ? "block" : "none";
            });
        });
    </script>
}